# ===============================
# ADMIN CREDENTIALS
# ===============================
# Email and password for the admin user
ADMIN_EMAIL=***REMOVED***
ADMIN_PASSWORD=***REMOVED***

# ===============================
# DATABASE CREDENTIALS
# ===============================
# Default works with H2 in-memory DB (zero config)
# For MySQL, replace with your DB username/password
DB_USERNAME=sa
DB_PASSWORD=

# ===============================
# JWT SECRET
# ===============================
# Used to sign JWT tokens
# Generate a secure random string for production, e.g. using https://randomkeygen.com/
JWT_SECRET=test-jwt-secret

# ===============================
# SENDGRID API KEY
# ===============================
# Used for sending emails via SendGrid
# To generate a key:
# 1. Sign up at https://sendgrid.com/
# 2. Create an API Key in Settings → API Keys
# 3. Replace the dummy value below with your real key
SENDGRID_API_KEY=test-sendgrid-key

# ===============================
# NOTES
# ===============================
# 1. Copy this file to create your local .env:
#    cp .env.example .env
# 2. Fill your real secrets in the copied .env for production use
# 3. Keep your real .env file ignored in .gitignore